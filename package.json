{
  "name": "stripe-vat-report",
  "version": "2.0.0",
  "description": "Multi-account Stripe VAT reports + real-time Slack notifications with admin GUI",
  "main": "dist/webhook.js",
  "scripts": {
    "build": "rm -rf dist && tsc && mkdir -p dist/public && find public -maxdepth 1 -type f \\( -name '*.html' -o -name '*.css' \\) -exec cp {} dist/public/ \\;",
    "start": "npm run build && node dist/webhook.js",
    "report": "npm run build && node dist/report.js",
    "create-user": "npm run build && node dist/scripts/create-user.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  }
}
